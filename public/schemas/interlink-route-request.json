{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["source_workspace_id", "target_workspace_id", "capability_id", "action", "routing_policy"],
  "properties": {
    "source_workspace_id": { "type": "string", "format": "uuid" },
    "target_workspace_id": { "type": "string" },
    "capability_id":       { "type": "string", "format": "uuid" },
    "action":              { "type": "string" },
    "routing_policy":      { "type": "string", "enum": ["nearest", "lowest_latency", "trust_weighted"] },
    "payload":             { "type": "object", "properties": { "params": { "type": "object" } } },
    "trace_id":            { "type": "string", "format": "uuid" }
  }
}
