{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capi.veklom.com/contracts/schemas/v1/ConnectionOperationV1.schema.json",
  "title": "ConnectionOperationV1",
  "description": "The envelope every governed operation must carry. All fields required.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspace_id",
    "connection_id",
    "connection_version",
    "operation_id",
    "attempt_id",
    "capability_id",
    "capability_version",
    "operation_hash",
    "schema_version",
    "subject_identity",
    "target_resource",
    "issued_at",
    "expires_at",
    "nonce",
    "idempotency_key",
    "trace_id",
    "policy_version"
  ],
  "properties": {
    "workspace_id": {
      "type": "string"
    },
    "connection_id": {
      "type": "string"
    },
    "connection_version": {
      "type": "string"
    },
    "operation_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "capability_id": {
      "type": "string"
    },
    "capability_version": {
      "type": "string"
    },
    "operation_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "schema_version": {
      "type": "string"
    },
    "subject_identity": {
      "$ref": "ExecutionIdentityV1.schema.json"
    },
    "target_resource": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "nonce": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    }
  }
}
