{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capi.veklom.com/contracts/schemas/v1/ApprovalReceiptV1.schema.json",
  "title": "ApprovalReceiptV1",
  "description": "Cryptographic proof that an authorized persona explicitly approved a held execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "execution_id",
    "approver_identity_id",
    "approved_at",
    "signature_key_id"
  ],
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "execution_id": {
      "type": "string"
    },
    "approver_identity_id": {
      "type": "string"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "signature_key_id": {
      "type": "string"
    },
    "issuer_identity": {
      "type": "string"
    },
    "constraints": {
      "type": "object"
    },
    "hashes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "single_use_identifiers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "signatures": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
