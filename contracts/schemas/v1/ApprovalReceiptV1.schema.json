{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capi.veklom.com/contracts/schemas/v1/ApprovalReceiptV1.schema.json",
  "title": "ApprovalReceiptV1",
  "description": "Signed record of a human/agent approval decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "execution_id",
    "approver_identity_id",
    "approved_at",
    "signature_key_id",
    "signature"
  ],
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "execution_id": {
      "type": "string"
    },
    "approver_identity_id": {
      "type": "string"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "signature_key_id": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    }
  }
}
