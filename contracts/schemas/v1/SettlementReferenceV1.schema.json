{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capi.veklom.com/contracts/schemas/v1/SettlementReferenceV1.schema.json",
  "title": "SettlementReferenceV1",
  "description": "Reference to an x402/CAPPO settlement. Money in integer minor units.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "settlement_id",
    "amount_minor",
    "currency",
    "network",
    "tx_hash",
    "settled_at"
  ],
  "properties": {
    "settlement_id": {
      "type": "string"
    },
    "amount_minor": {
      "type": "integer",
      "description": "Integer minor units. No floating-point monetary values."
    },
    "currency": {
      "type": "string"
    },
    "network": {
      "type": [
        "string",
        "null"
      ]
    },
    "tx_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "settled_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
