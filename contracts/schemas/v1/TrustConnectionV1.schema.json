{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capi.veklom.com/contracts/schemas/v1/TrustConnectionV1.schema.json",
  "title": "TrustConnectionV1",
  "description": "A governed Trust Connection between participants in a workspace.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "connection_id",
    "connection_version",
    "workspace_id",
    "state",
    "schema_version",
    "policy_version",
    "participants",
    "created_at",
    "updated_at",
    "terminated_at"
  ],
  "properties": {
    "connection_id": {
      "type": "string"
    },
    "connection_version": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "suspended",
        "terminated"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "items": {
        "$ref": "ConnectionParticipantV1.schema.json"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "terminated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
