{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capi.veklom.com/contracts/schemas/v1/TrustConnectionV1.schema.json",
  "title": "TrustConnectionV1",
  "description": "The root state document for a negotiated, governed connection between two participants.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "connection_id",
    "version",
    "workspace_id",
    "state",
    "schema_version",
    "policy_version",
    "participants",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "connection_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "NEGOTIATING",
        "ACTIVE",
        "DEGRADED",
        "SUSPENDED",
        "TERMINATING",
        "TERMINATED",
        "REJECTED",
        "REVOKED",
        "EXPIRED",
        "FAILED"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "items": {
        "$ref": "ConnectionParticipantV1.schema.json"
      }
    },
    "provider_identity": {
      "type": "string"
    },
    "target_resource_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "capability_sets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "settlement_profiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "terminated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
