{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capi.veklom.com/contracts/schemas/v1/TrustConnectionV1.schema.json",
  "title": "TrustConnectionV1",
  "description": "A governed Trust Connection between participants in a workspace.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "connection_id",
    "connection_version",
    "workspace_id",
    "state",
    "schema_version",
    "policy_version",
    "participants",
    "provider_identity",
    "target_resource_id",
    "target_resource_kind",
    "capability_set_id",
    "capability_set_version",
    "condition_set_version",
    "measurement_profile_id",
    "settlement_profile_id",
    "activation_evidence_hash",
    "latest_transition_id",
    "created_at",
    "updated_at",
    "terminated_at"
  ],
  "properties": {
    "connection_id": {
      "type": "string"
    },
    "connection_version": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "proposed",
        "negotiating",
        "active",
        "degraded",
        "suspended",
        "terminating",
        "terminated",
        "rejected",
        "revoked",
        "expired",
        "failed"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "items": {
        "$ref": "ConnectionParticipantV1.schema.json"
      }
    },
    "provider_identity": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_resource_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_resource_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "capability_set_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "capability_set_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "condition_set_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "measurement_profile_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "settlement_profile_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "activation_evidence_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "latest_transition_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "terminated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
